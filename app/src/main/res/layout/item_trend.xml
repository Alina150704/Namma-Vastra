<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Color Preview Box -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <View
                android:id="@+id/trendImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FF69B4" />

            <TextView
                android:id="@+id/monthBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/month_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Dec 2024"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/demandBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:background="@drawable/demand_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="🔥 High Demand"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/trendTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1C1B1F"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/trendDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎨 Color Palette"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3780"
                android:layout_marginBottom="8dp" />

            <!-- ChipGroup for colors - ADDED ID -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/colorChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:chipSpacing="8dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Color Popularity"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3780"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/colorPopularityContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Best For"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3780"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/bestForText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cotton Kurtis, Summer Sarees"
                android:textSize="13sp"
                android:textColor="#49454F"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Popular In"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A3780"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/popularCitiesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bengaluru, Chennai, Mumbai"
                android:textSize="13sp"
                android:textColor="#49454F"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF3E0"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFF3E0">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 Why Trending?"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/whyTrendingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Summer collection releases and wedding season demand"
                    android:textSize="12sp"
                    android:textColor="#BF360C" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EDE7F6"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#EDE7F6">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Style Suggestion"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#4A148C"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/aiSuggestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pair Mint Green with cream silk for a fresh summer look"
                    android:textSize="12sp"
                    android:textColor="#311B92"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewDesigns"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="👁️ View Designs"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:backgroundTint="#6750A4"
                    app:cornerRadius="20dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFabricMatch"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🧵 Fabric Match"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FF9800"
                    app:cornerRadius="20dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveTrend"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="❤️ Save"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:backgroundTint="#E91E63"
                    app:cornerRadius="20dp"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>